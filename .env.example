# Database
# Local dev (default): SQLite — works without a Postgres server
DATABASE_URL="file:./dev.db"

# Production: PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/life_os"

# Better Auth
BETTER_AUTH_SECRET="generate-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Coach
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Cron automation (POST /api/coach/cron/dispatch with Authorization: Bearer CRON_SECRET)
# Body: { "mode": "morning" | "evening" | "weekly", "userId": "optional" }
CRON_SECRET=""

# Supabase Storage (optional)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Pro upgrade billing (Paystack) — get keys from https://dashboard.paystack.com/#/settings/developer
# Without this set, /billing checkout returns "Payments are not configured yet."
# Also set the webhook URL in the Paystack dashboard to: <APP_URL>/api/billing/webhook
PAYSTACK_SECRET_KEY=""
