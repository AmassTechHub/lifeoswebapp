generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Better Auth tables — extend as auth is wired up
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  openAiKey  String?

  // Onboarding
  onboardingCompleted Boolean @default(false)
  useCase             String? // JSON array: ["student","creator",...]
  primaryGoal         String?
  workSchedule        String? // JSON: {"days":["Mon",...],"startTime":"09:00","endTime":"17:00"}

  goals      Goal[]
  tasks      Task[]
  habits     Habit[]
  expenses   Expense[]
  incomes    Income[]
  clients    Client[]
  learnings  LearningTopic[]
  content    ContentItem[]
  studyCourses  StudyCourse[]
  flashcards    Flashcard[]
  studySessions StudySession[]
  calendarEvents CalendarEvent[]
  timetableFiles TimetableFile[]
  daySnapshots   DaySnapshot[]
  workspaceDocs  WorkspaceDoc[]
  lifeCycleLogs  LifeCycleLog[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum GoalLevel {
  VISION
  ANNUAL
  QUARTERLY
  MONTHLY
  WEEKLY
  DAILY
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  level       GoalLevel
  parentId    String?
  parent      Goal?     @relation("GoalHierarchy", fields: [parentId], references: [id])
  children    Goal[]    @relation("GoalHierarchy")
  targetDate  DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum TaskStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskCategory {
  ACADEMICS
  CODING
  CONTENT
  CLIENTS
  PERSONAL
}

model Task {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  status        TaskStatus   @default(BACKLOG)
  category      TaskCategory @default(PERSONAL)
  studyCourseId String?
  studyCourse   StudyCourse? @relation(fields: [studyCourseId], references: [id], onDelete: SetNull)
  dueDate       DateTime?
  completed     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Habit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  completed Boolean  @default(true)

  @@unique([habitId, date])
}

model LearningTopic {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String
  learned      Boolean  @default(false)
  practiced    Boolean  @default(false)
  built        Boolean  @default(false)
  confidence   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ContentStage {
  IDEA
  SCRIPT
  RECORDING
  EDITING
  PUBLISHED
}

model ContentItem {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  channel   String
  stage     ContentStage @default(IDEA)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliverables ClientDeliverable[]
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model ClientDeliverable {
  id        String            @id @default(cuid())
  clientId  String
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  status    DeliverableStatus @default(PENDING)
  amount    Float?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

enum EventCategory {
  PERSONAL
  ACADEMICS
  CODING
  CONTENT
  CLIENTS
  CHURCH
  OTHER
}

enum EventSource {
  MANUAL
  TIMETABLE
  SYSTEM
}

model CalendarEvent {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  startAt       DateTime
  endAt         DateTime
  category      EventCategory @default(PERSONAL)
  source        EventSource   @default(MANUAL)
  studyCourseId String?
  studyCourse   StudyCourse?  @relation(fields: [studyCourseId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, startAt])
}

model TimetableFile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  mimeType  String?
  createdAt DateTime @default(now())
}

model DaySnapshot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  score     Int
  breakdown String
  focusJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model Expense {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  category      String
  description   String?
  paymentMethod String   @default("CASH")
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Income {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  source      String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Study hub: classes like DSA — notes, summaries, slide uploads
model StudyCourse {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes          StudyNote[]
  materials      StudyMaterial[]
  flashcards     Flashcard[]
  tasks          Task[]
  calendarEvents CalendarEvent[]
  scheduleSlots  CourseSchedule[]
  studySessions  StudySession[]
}

model CourseSchedule {
  id         String      @id @default(cuid())
  courseId   String
  course     StudyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  venue      String?
  createdAt  DateTime    @default(now())
}

model Flashcard {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String?
  course    StudyCourse? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  front     String
  back      String
  // Spaced repetition
  difficulty     Int       @default(0) // 0=new, 1=easy, 2=medium, 3=hard
  reviewCount    Int       @default(0)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum StudyNoteType {
  NOTE
  SUMMARY
  LECTURE
}

model StudyNote {
  id        String        @id @default(cuid())
  courseId  String
  course    StudyCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  content   String        @default("")
  type      StudyNoteType @default(NOTE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model StudyMaterial {
  id        String      @id @default(cuid())
  courseId  String
  course    StudyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  fileName  String
  fileUrl   String
  mimeType  String?
  fileSize  Int?
  createdAt DateTime    @default(now())
}

model WorkspaceDoc {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("")
  folder    String   @default("General")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudySession {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String?
  course        StudyCourse? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  cardsReviewed Int          @default(0)
  cardsCorrect  Int          @default(0)
  durationSecs  Int          @default(0)
  startedAt     DateTime     @default(now())
  endedAt       DateTime?
  createdAt     DateTime     @default(now())

  @@index([userId, startedAt])
}

enum LifeCycleType {
  MORNING
  EVENING
  WEEKLY
}

model LifeCycleLog {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      LifeCycleType
  date      DateTime
  summary   String
  payload   String        @default("{}")
  createdAt DateTime      @default(now())

  @@unique([userId, type, date])
}
